# ===== TickFlow =====
# 留空或不填则启用 Free 试用模式(TickFlow.free()),仅能拿历史日 K 单股数据
TICKFLOW_API_KEY=

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO

# ===== Auth (多用户) =====
# 首次启动时预置超级管理员账号 (公网部署免 SSH 端口转发建账号)。
# 仅在尚未创建任何账号时生效 (一次性初始化); 之后改密码/用户管理走页面 UI (设置 → 用户管理)。
# 建议密码至少 6 位。.env 文件权限保持 600 且不要提交到 Git。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 兼容旧版: 若仅设 AUTH_PASSWORD, 用它作 admin 密码 (用户名取 ADMIN_USERNAME)。
# 新部署请改用 ADMIN_PASSWORD。后续版本将移除此项。
AUTH_PASSWORD=

# Optional Docker build extras. Set to legacy-cpu on older VPS hosts
# without AVX2/FMA support.
BACKEND_EXTRAS=

# ===== Data =====
DATA_DIR=./data
