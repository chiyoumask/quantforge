# ===== TickFlow (付费兜底源, 可选) =====
# 已降级为「付费备份」。默认免费历史/盘后数据走 akshare, 盘中实时走 eastmoney。
# 仅当你需要 TickFlow 高级能力(如五档盘口 Pro+ 之外、付费批量)时才填。
# 留空 = 完全免费模式(akshare/eastmoney/sina/qq 免费源, 无需任何 key)。
TICKFLOW_API_KEY=

# ===== 数据源选择 (可选, 均可省略) =====
# 历史/盘后: akshare(默认免费) | tickflow(付费) | eastmoney | sina | qq
DAILY_DATA_PROVIDER=akshare
# 分钟K: 同 DAILY_DATA_PROVIDER 取值 (默认 akshare)
MINUTE_DATA_PROVIDER=akshare
# 盘中实时: eastmoney(默认免费全市场) | akshare | sina | qq | tickflow(付费)
REALTIME_DATA_PROVIDER=eastmoney

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO
# 容器时区, 同时被 docker-compose.yml 注入, 这里写入则作为默认值
TZ=Asia/Shanghai

# ===== Auth (多用户) =====
# 首次启动时预置超级管理员账号 (公网部署免 SSH 端口转发建账号)。
# 仅在尚未创建任何账号时生效 (一次性初始化); 之后改密码/用户管理走页面 UI (设置 → 用户管理)。
# 建议密码至少 6 位。.env 文件权限保持 600 且不要提交到 Git。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 兼容旧版: 若仅设 AUTH_PASSWORD, 用它作 admin 密码 (用户名取 ADMIN_USERNAME)。
# 新部署请改用 ADMIN_PASSWORD。后续版本将移除此项。
AUTH_PASSWORD=

# Optional Docker build extras. Set to legacy-cpu on older VPS hosts
# without AVX2/FMA support.
BACKEND_EXTRAS=

# ===== Data =====
DATA_DIR=./data
